# Supabase project
SUPABASE_URL=https://ljzypuiqebttfmmgzsqk.supabase.co

# Safe for browser usage with proper RLS policies.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_[YOUR-PUBLISHABLE-KEY]

# Server-side only. Never expose it in templates or frontend bundles.
SUPABASE_SECRET_KEY=sb_secret_[YOUR-SECRET-KEY]

# Optional explicit alias for backend server requests.
# SUPABASE_SERVER_KEY=sb_secret_[YOUR-SECRET-KEY]

# Django admin / ORM connection to Supabase Postgres.
# Replace [YOUR-PASSWORD] with the real database password from Supabase.
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.ljzypuiqebttfmmgzsqk.supabase.co:5432/postgres?sslmode=require

# Optional alias used by many deployments.
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.ljzypuiqebttfmmgzsqk.supabase.co:5432/postgres?sslmode=require

# Enforce Supabase DB in local dev and avoid fallback to sqlite.
FORCE_SUPABASE_DB=true
